# ── apps/web (used today) ────────────────────────────
# Postgres with the pgvector extension. Neon (serverless) recommended.
DATABASE_URL=postgresql://user:pass@host:5432/playlist_analyzer

# Auth.js — generate with `openssl rand -base64 32`
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# External music / AI APIs
LASTFM_API_KEY=
GEMINI_API_KEY=
# Optional model overrides — defaults are sensible for the cost/quality split.
# Track analysis (bulk, cheap): gemini-2.0-flash
# Psychology profile (high-value, single call): gemini-2.5-pro
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODEL_PROFILE=gemini-2.5-pro
# Deezer / MusicBrainz / iTunes Search need no auth.

# ── services/analysis (Phase 3, not built yet) ───────
REDIS_URL=redis://localhost:6379/0
MUSICBRAINZ_USER_AGENT=playlist-analyzer/0.1 (contact@example.com)
