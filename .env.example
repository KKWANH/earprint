# ── apps/web (used today) ────────────────────────────
# Postgres with the pgvector extension. Neon (serverless) recommended.
DATABASE_URL=postgresql://user:pass@host:5432/playlist_analyzer

# Auth.js — generate with `openssl rand -base64 32`
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# External music / AI APIs
LASTFM_API_KEY=
GEMINI_API_KEY=
# Optional second AI provider (Moonshot Kimi). When set, AI calls can race
# Gemini + Kimi in parallel for ~50% lower latency + automatic fallback.
# Leave blank to use Gemini only.
KIMI_API_KEY=
# AI dispatcher strategy: race (default when both keys set) | split | gemini | kimi
AI_MODE=race
# KIMI_MODEL=kimi-k2-0905-preview
# Deezer / MusicBrainz / iTunes Search need no auth.

# ── services/analysis (Phase 3, not built yet) ───────
REDIS_URL=redis://localhost:6379/0
MUSICBRAINZ_USER_AGENT=playlist-analyzer/0.1 (contact@example.com)
