# ── 공통 ──────────────────────────────────────────────
# Postgres (pgvector 확장 필요). Supabase/Neon 또는 로컬.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/playlist_analyzer

# Redis (큐 / rate-limit 예산 / 캐시)
REDIS_URL=redis://localhost:6379/0

# ── apps/web ─────────────────────────────────────────
# Auth.js — `openssl rand -base64 32` 로 생성
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# 분석 서비스 내부 호출 주소
ANALYSIS_SERVICE_URL=http://localhost:8000

# ── services/analysis ────────────────────────────────
# 외부 음악 API
LASTFM_API_KEY=
# Deezer / MusicBrainz / iTunes Search 는 무인증 (User-Agent 만 권장)
MUSICBRAINZ_USER_AGENT=playlist-analyzer/0.1 (contact@example.com)

# Cloudflare R2 (오브젝트 스토리지)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=playlist-analyzer
