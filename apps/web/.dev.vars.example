# Environment variables for local `wrangler preview`. Copy to .dev.vars.
#   cp .dev.vars.example .dev.vars
# (`next dev` uses the repo-root .env; .dev.vars is for wrangler preview/deploy.)

DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/playlist_analyzer?sslmode=require
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=http://localhost:8788
AUTH_TRUST_HOST=true
LASTFM_API_KEY=
GEMINI_API_KEY=
# Optional second AI provider — when set, AI requests can race Gemini + Kimi.
KIMI_API_KEY=
# race (default with both keys) | split | gemini | kimi
AI_MODE=race
